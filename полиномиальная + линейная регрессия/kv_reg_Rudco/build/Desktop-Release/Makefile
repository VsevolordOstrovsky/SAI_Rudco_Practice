####### Compile

qcustomplot.o: ../../scr/qcustomplot/qcustomplot.cpp ../../scr/qcustomplot/qcustomplot.h
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o qcustomplot.o ../../scr/qcustomplot/qcustomplot.cpp

main.o: ../../main.cpp ../../lin_reg.h \
		../../scr/qcustomplot/qcustomplot.h
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o main.o ../../main.cpp

lin_reg.o: ../../lin_reg.cpp ../../lin_reg.h \
		../../scr/qcustomplot/qcustomplot.h \
		ui_lin_reg.h
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o lin_reg.o ../../lin_reg.cpp

moc_qcustomplot.o: moc_qcustomplot.cpp 
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o moc_qcustomplot.o moc_qcustomplot.cpp

